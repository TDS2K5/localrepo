from array import *

def sel(a,n):
    for i in range(n-1):
        mini=i
        for j in range(i+1,n):
            if A[j]<A[mini]:
                mini=j
        A[i],A[mini]=A[mini],A[i]

    return A


n=int(input("enter no of elements: "))
A=array('i',[])
for i in range(n):
    A.append(int(input(f"enter array element {i}:  ")))

print("array before sorting: ",A)
bkc=sel(A,n)
